# source: D:\workspace\SHLTests\problems\consecutive_increasing_sequence\solution.py
# lines: 3-12

        return 0
    best = 1
    cur = 1
    for i in range(1, len(nums)):
        if nums[i] > nums[i - 1]:
            cur += 1
            best = max(best, cur)
        else:
            cur = 1
    return best

