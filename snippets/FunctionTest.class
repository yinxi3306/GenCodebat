def throttle_requests(requests: list[tuple[str, int]]) -> list[bool]:
    from collections import defaultdict

    accepted: dict[str, list[int]] = defaultdict(list)
    out: list[bool] = []
    for ip, t in requests:
        ts = accepted[ip]
        window = [x for x in ts if t - 9 <= x <= t]
        accepted[ip] = window
        if len(window) < 5:

